APP_NAME="رابطة سوق السيارات"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sayarat_db
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# File storage is local disk for now (php artisan storage:link). Cloud storage
# (S3/R2) is a planned follow-up task — do not set FILESYSTEM_DISK to s3/r2
# until that work lands and credentials exist.
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="رابطة سوق السيارات"

# Path to the Firebase service-account JSON, or the raw JSON string itself.
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

{
  "info": {
    "name": "رابطة سوق السيارات — Car Marketplace API",
    "description": "Complete REST API collection for the Car Marketplace project — mobile app + admin dashboard.\n\nLive server: https://api-rabta.rabtetsouqelsayarat.com\n\nSet {{base_url}} to switch between local dev and the live server. {{mobile_token}} and {{admin_token}} auto-populate after Login/Admin Login thanks to test scripts — you do not need to copy tokens manually.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "cars-marketplace-v2"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api-rabta.rabtetsouqelsayarat.com/api",
      "type": "string"
    },
    {
      "key": "mobile_url",
      "value": "{{base_url}}/v1/mobile",
      "type": "string"
    },
    {
      "key": "admin_url",
      "value": "{{base_url}}/admin",
      "type": "string"
    },
    {
      "key": "core_url",
      "value": "{{base_url}}/core",
      "type": "string"
    },
    {
      "key": "mobile_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "locale",
      "value": "ar",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🌍 Core",
      "item": [
        {
          "name": "App Config (Maintenance / Version Gate)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "{{locale}}"
              }
            ],
            "url": {
              "raw": "{{core_url}}/app-config?platform=android&version=1.0.0&language={{locale}}",
              "host": [
                "{{core_url}}"
              ],
              "path": [
                "app-config"
              ],
              "query": [
                {
                  "key": "platform",
                  "value": "android"
                },
                {
                  "key": "version",
                  "value": "1.0.0"
                },
                {
                  "key": "language",
                  "value": "{{locale}}"
                }
              ]
            }
          }
        },
        {
          "name": "Terms & Conditions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "{{locale}}"
              }
            ],
            "url": {
              "raw": "{{core_url}}/terms",
              "host": [
                "{{core_url}}"
              ],
              "path": [
                "terms"
              ]
            }
          }
        }
      ]
    },
    {

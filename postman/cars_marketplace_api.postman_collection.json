            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\",\n  \"fcm_token\": \"optional-device-fcm-token\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('mobile_token', json.data.token);",
                  "}"
